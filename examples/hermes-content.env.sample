# Hermes -> Codex -> Telegram -> Meta publishing local env.
# Copy this to carousel-workspace/hermes-content.env and fill values locally.
# Never paste real tokens into chat. Never commit the real env file.

# 1) Telegram review bot
# Create a bot with @BotFather, send /start to the bot, then run:
#   node tools/automation/hermes-telegram-check.mjs
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 2) Instagram Graph API
# META_ACCESS_TOKEN: long-lived user token or system user token with Instagram publish permissions.
# INSTAGRAM_USER_ID: the Instagram professional account id, not your personal Facebook user id.
# META_TOKEN_EXPIRES_AT: optional ISO date, e.g. 2026-08-30T00:00:00+09:00
META_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
META_TOKEN_EXPIRES_AT=
# For Instagram API with Instagram Login tokens, keep this as graph.instagram.com.
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com/v25.0

# 3) Threads API
# Use a Threads token/user id for the ai_jjuun Threads profile.
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_TOKEN_EXPIRES_AT=
THREADS_GRAPH_BASE_URL=https://graph.threads.net/v1.0

# 4) Public media URL
# Meta APIs cannot upload local C:\ files directly.
# Put exported images/videos somewhere public, then set the base URL here.
# Example: https://cdn.example.com/ai-jjuun/
PUBLIC_MEDIA_BASE_URL=

# 5) Telegram final approval auto publish
# When this is enabled, final ㄱㄱ/UPLOAD triggers CDN deploy + Meta upload.
AIJJUN_CDN_REPO_PATH=ai-jjun-cdn
HERMES_AUTO_PUBLISH_ON_FINAL_APPROVAL=1
HERMES_AUTO_PUBLISH_EXECUTE=1
HERMES_AUTO_PUBLISH_PLATFORM=auto
HERMES_AUTO_PUBLISH_KINDS=carousel,reel

# 6) YouTube Data API, later
# OAuth refresh token must include https://www.googleapis.com/auth/youtube.upload scope.
# Default privacy is private so Hermes can upload draft Shorts for review first.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=28
YOUTUBE_MADE_FOR_KIDS=false
YOUTUBE_TAGS=AI,AI쭌,Codex
